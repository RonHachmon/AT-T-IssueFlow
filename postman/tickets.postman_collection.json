              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body is JSON array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
              "pm.test('Body shape includes README keys (id, title, status, priority, type, projectId)', function () {",
              "  if (pm.response.json().length > 0) {",
              "    pm.expect(pm.response.json()[0]).to.include.keys('id','title','status','priority','type','projectId');",
              "  }",
              "});",
              "pm.test('Soft-deleted ticket is in the list', function () {",
              "  const id = Number(pm.collectionVariables.get('createdTicketId'));",
              "  pm.expect(pm.response.json().map(t => t.id)).to.include(id);",
              "});"
            ]
          }
        }
      ]
