    {
      "name": "List deleted tickets as ADMIN -> 200 includes deleted",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/tickets/deleted?projectId=1",
          "host": ["{{baseUrl}}"],
          "path": ["tickets", "deleted"],
          "query": [
            { "key": "projectId", "value": "1" }
          ]
