    {
      "name": "Create ticket — valid -> 200",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Fix login bug\",\n  \"description\": \"Users cannot log in with SSO\",\n  \"priority\": \"HIGH\",\n  \"type\": \"BUG\",\n  \"projectId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tickets",
          "host": ["{{baseUrl}}"],
          "path": ["tickets"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body has expected shape', function () { pm.expect(pm.response.json()).to.include.keys('id','title','status','priority','type','projectId','isOverdue'); });",
              "pm.test('status is TODO', function () { pm.expect(pm.response.json().status).to.eql('TODO'); });",
              "pm.test('isOverdue is false', function () { pm.expect(pm.response.json().isOverdue).to.be.false; });",
              "pm.collectionVariables.set('createdTicketId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
