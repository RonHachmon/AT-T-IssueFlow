{
  "info": {
    "name": "IssueFlow – Mentions API",
    "_postman_id": "mentions-collection-v1",
    "description": "End-to-end tests for GET /users/:userId/mentions: defaults, paging, validation, and 404s.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "GET – mentions for current user (defaults)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.sendRequest({",
              "  url: pm.environment.get('baseUrl') + '/auth/me',",
              "  method: 'GET',",
              "  header: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
              "}, function(err, res) {",
              "  pm.variables.set('currentUserId', res.json().id);",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('data is an array', () => pm.expect(body.data).to.be.an('array'));",
              "pm.test('page defaults to 1', () => pm.expect(body.page).to.eql(1));",
              "pm.test('pageSize defaults to 20', () => pm.expect(body.pageSize).to.eql(20));",
              "pm.test('total is a number', () => pm.expect(body.total).to.be.a('number'));",
              "body.data.forEach(item => {",
              "  pm.test('each item has mentionedUsers array', () => pm.expect(item.mentionedUsers).to.be.an('array'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users/{{currentUserId}}/mentions",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{currentUserId}}", "mentions"]
        }
      }
    },
    {
      "name": "GET – mentions with custom page and pageSize",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.sendRequest({",
              "  url: pm.environment.get('baseUrl') + '/auth/me',",
              "  method: 'GET',",
              "  header: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
              "}, function(err, res) {",
              "  pm.variables.set('currentUserId', res.json().id);",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('echoes requested page', () => pm.expect(body.page).to.eql(2));",
              "pm.test('echoes requested pageSize', () => pm.expect(body.pageSize).to.eql(5));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users/{{currentUserId}}/mentions?page=2&pageSize=5",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{currentUserId}}", "mentions"],
          "query": [
            {"key": "page", "value": "2"},
            {"key": "pageSize", "value": "5"}
          ]
        }
      }
    },
    {
      "name": "GET – 422 on pageSize=0",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.sendRequest({",
              "  url: pm.environment.get('baseUrl') + '/auth/me',",
              "  method: 'GET',",
              "  header: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
              "}, function(err, res) {",
              "  pm.variables.set('currentUserId', res.json().id);",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 422', () => pm.response.to.have.status(422));",
              "pm.test('Content-Type is application/problem+json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users/{{currentUserId}}/mentions?pageSize=0",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{currentUserId}}", "mentions"],
          "query": [
            {"key": "pageSize", "value": "0"}
          ]
        }
      }
    },
    {
      "name": "GET – 422 on pageSize=101 (above max)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.sendRequest({",
              "  url: pm.environment.get('baseUrl') + '/auth/me',",
              "  method: 'GET',",
              "  header: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
              "}, function(err, res) {",
              "  pm.variables.set('currentUserId', res.json().id);",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 422', () => pm.response.to.have.status(422));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users/{{currentUserId}}/mentions?pageSize=101",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{currentUserId}}", "mentions"],
          "query": [
            {"key": "pageSize", "value": "101"}
          ]
        }
      }
    },
    {
      "name": "GET – 404 on non-existent user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 404', () => pm.response.to.have.status(404));",
              "pm.test('Content-Type is application/problem+json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users/999999/mentions",
          "host": ["{{baseUrl}}"],
          "path": ["users", "999999", "mentions"]
        }
      }
    }
  ]
}
