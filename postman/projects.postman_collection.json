{
  "info": {
    "name": "IssueFlow — Projects",
    "description": "Project CRUD: create, get, list, update, soft-delete, and error cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "00000000-0000-0000-0000-000000000005"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{baseUrl}}",
      "type": "string"
    },
    {
      "key": "createdProjectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "developerToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create project — valid → 200",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Backend Rewrite\",\n  \"description\": \"Modernise the service layer\",\n  \"ownerId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body shape matches README (id, name, description, ownerId)', function () {",
              "  pm.expect(pm.response.json()).to.have.all.keys('id', 'name', 'description', 'ownerId');",
              "});",
              "pm.test('Name matches request', function () {",
              "  pm.expect(pm.response.json().name).to.eql('Backend Rewrite');",
              "});",
              "pm.collectionVariables.set('createdProjectId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create project — missing name → 400",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"No name supplied\",\n  \"ownerId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', function () { pm.response.to.have.status(400); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Create project — unknown ownerId → 404",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Orphan Project\",\n  \"ownerId\": 999999\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404', function () { pm.response.to.have.status(404); });",
              "pm.test('Body is problem+json with not-found type', function () {",
              "  pm.expect(pm.response.json().type).to.include('not-found');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create project — duplicate name → 409",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"BACKEND REWRITE\",\n  \"ownerId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        },
        "description": "Run after 'Create project — valid'. BACKEND REWRITE collides case-insensitively."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 409', function () { pm.response.to.have.status(409); });",
              "pm.test('Body is problem+json with duplicate-resource type', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json');",
              "  pm.expect(pm.response.json().type).to.include('duplicate-resource');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List projects → 200 array",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body is a JSON array per README', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get project by ID — active → 200",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body shape matches README', function () {",
              "  pm.expect(pm.response.json()).to.have.all.keys('id', 'name', 'description', 'ownerId');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update project — valid name → 200 empty",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Renamed Project\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body is empty', function () {",
              "  pm.expect(pm.response.text()).to.eql('');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update project — empty body → 400",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', function () { pm.response.to.have.status(400); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete project → 200 empty",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body is empty', function () {",
              "  pm.expect(pm.response.text()).to.eql('');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get soft-deleted project → 404",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        },
        "description": "Run after 'Delete project'. The deleted project must not be visible."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404', function () { pm.response.to.have.status(404); });",
              "pm.test('Body is problem+json with not-found type', function () {",
              "  pm.expect(pm.response.json().type).to.include('not-found');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete same project again → 404",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        },
        "description": "Idempotency check: second delete must return 404."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404', function () { pm.response.to.have.status(404); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Setup – login as developer (for 403 checks)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"developer\",\"password\":\"Dev1234!\"}" },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Developer login succeeds', function () { pm.response.to.have.status(200); });",
              "pm.collectionVariables.set('developerToken', pm.response.json().accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "List deleted projects as ADMIN → 200 includes deleted",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/deleted",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "deleted"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body is JSON array', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "pm.test('Body shape matches README (id, name, description, ownerId)', function () {",
              "  if (pm.response.json().length > 0) {",
              "    pm.expect(pm.response.json()[0]).to.have.all.keys('id', 'name', 'description', 'ownerId');",
              "  }",
              "});",
              "pm.test('Soft-deleted project is in the list', function () {",
              "  const id = Number(pm.collectionVariables.get('createdProjectId'));",
              "  pm.expect(pm.response.json().map(p => p.id)).to.include(id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List deleted projects as DEVELOPER → 403",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{developerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/deleted",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "deleted"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 403', function () { pm.response.to.have.status(403); });",
              "pm.test('Body is problem+json with forbidden type', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json');",
              "  pm.expect(pm.response.json().type).to.include('forbidden');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Restore project as DEVELOPER → 403",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{developerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}/restore",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}", "restore"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 403', function () { pm.response.to.have.status(403); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Restore project as ADMIN → 200 empty",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}/restore",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}", "restore"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Body is empty', function () {",
              "  pm.expect(pm.response.text()).to.eql('');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get restored project → 200 (visible again)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Restore already-active project → 404",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{createdProjectId}}/restore",
          "host": ["{{baseUrl}}"],
          "path": ["projects", "{{createdProjectId}}", "restore"]
        },
        "description": "Restore is only meaningful for soft-deleted projects. Calling it on an active project returns 404."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404', function () { pm.response.to.have.status(404); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Projects — No auth → 401",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    }
  ]
}
