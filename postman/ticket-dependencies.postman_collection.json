    {
      "name": "GET — list dependencies -> 200 with one row",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/tickets/{{blockedId}}/dependencies",
          "host": ["{{baseUrl}}"],
          "path": ["tickets", "{{blockedId}}", "dependencies"]
        }
