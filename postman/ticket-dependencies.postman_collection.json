    {
      "name": "PATCH — blocked cannot reach DONE while blocker open -> 409",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Advance blocked through TODO -> IN_PROGRESS -> IN_REVIEW so DONE is one step away.",
              "const id = pm.collectionVariables.get('blockedId');",
              "const baseUrl = pm.environment.get('baseUrl');",
              "const auth = { 'Authorization': 'Bearer ' + pm.environment.get('authToken'), 'Content-Type': 'application/json' };",
              "function advance(status, cb) {",
              "  pm.sendRequest({ url: baseUrl + '/tickets/' + id, method: 'PATCH', header: auth, body: { mode: 'raw', raw: JSON.stringify({ status }) } }, cb);",
              "}",
              "advance('IN_PROGRESS', () => advance('IN_REVIEW', () => {}));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 409', () => pm.response.to.have.status(409));",
              "pm.test('Detail mentions blockers', () => pm.expect(pm.response.json().detail).to.match(/blockers/i));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"status\": \"DONE\" }"
        },
        "url": {
          "raw": "{{baseUrl}}/tickets/{{blockedId}}",
          "host": ["{{baseUrl}}"],
          "path": ["tickets", "{{blockedId}}"]
