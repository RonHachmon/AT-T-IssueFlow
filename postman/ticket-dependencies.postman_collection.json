          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Is array', () => pm.expect(body).to.be.an('array'));",
              "pm.test('Has one row', () => pm.expect(body.length).to.eql(1));",
              "pm.test('Row has id/title/status', () => pm.expect(body[0]).to.include.keys('id','title','status'));",
              "pm.test('Row id matches blocker', () => pm.expect(body[0].id).to.eql(pm.collectionVariables.get('blockerId') * 1));"
            ]
          }
        }
      ]
