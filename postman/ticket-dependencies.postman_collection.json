          "raw": "{\n  \"name\": \"DepCollection A\",\n  \"description\": \"Auto-created by Postman dependency tests\",\n  \"ownerId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": ["{{baseUrl}}"],
          "path": ["projects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('projectAId', pm.response.json().id);"
            ]
